# ─── Application ──────────────────────────────────────────────────────────────
APP_TITLE="EIR OCR Platform"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# ─── Extraction ───────────────────────────────────────────────────────────────
# Choices:
#   vertex     — Google Gemini via Vertex AI or Google AI API (remote, requires GOOGLE_API_KEY or GOOGLE_CLOUD_PROJECT)
#   azure      — Azure Document Intelligence (remote, requires AZURE_DOCINTEL_ENDPOINT + KEY)
#   paddle     — PaddleOCR 2.x CPU mode (local, pip install paddlepaddle paddleocr)
#   paddle_vl  — PaddleOCR-VL 0.9B vision-language model (fully local, no cloud credentials needed)
#                PaddlePaddle only supports Python 3.9–3.13, so it runs in a separate interpreter.
#                One-time setup:
#                  python3.13 -m venv /opt/paddle-venv
#                  /opt/paddle-venv/bin/pip install paddlepaddle 'paddleocr[doc-parser]'
#                Then set PADDLE_VL_PYTHON below and EXTRACTION_PROVIDER=paddle_vl.
#                Model weights (~1 GB) are downloaded automatically on first run.
EXTRACTION_PROVIDER=vertex

# ─── PaddleOCR-VL subprocess bridge ───────────────────────────────────────────
# Full path to a Python 3.9–3.13 interpreter that has paddleocr[doc-parser] installed.
# Only used when EXTRACTION_PROVIDER=paddle_vl.
#
# One-time setup — choose the install command that matches your GPU:
#
#   NVIDIA Blackwell GPU (RTX 5060/5070/5080/5090, sm_120)
#   Requires NVIDIA driver ≥ 580 (CUDA 12.9 runtime support):
#     python3.13 -m venv /opt/paddle-venv
#     /opt/paddle-venv/bin/pip install paddlepaddle-gpu==3.2.1 \
#         -i https://www.paddlepaddle.org.cn/packages/stable/cu129/
#     /opt/paddle-venv/bin/pip install 'paddleocr[doc-parser]'
#     /opt/paddle-venv/bin/pip install "numpy<2.0"   # PaddlePaddle 3.x requires numpy 1.x
#
#   NVIDIA Ampere / Ada GPU (RTX 30xx / 40xx, CUDA 12.3):
#     python3.13 -m venv /opt/paddle-venv
#     /opt/paddle-venv/bin/pip install paddlepaddle-gpu==3.0.0 \
#         -i https://www.paddlepaddle.org.cn/packages/stable/cu123/
#     /opt/paddle-venv/bin/pip install 'paddleocr[doc-parser]'
#     /opt/paddle-venv/bin/pip install "numpy<2.0"
#
#   CPU only:
#     python3.13 -m venv /opt/paddle-venv
#     /opt/paddle-venv/bin/pip install paddlepaddle 'paddleocr[doc-parser]'
#     /opt/paddle-venv/bin/pip install "numpy<2.0"
#
PADDLE_VL_PYTHON=/opt/paddle-venv/bin/python

# PaddlePaddle device string passed to PaddleOCRVL(device=...).
# Options: gpu (default) | gpu:0 | gpu:1 | cpu
PADDLE_VL_DEVICE=gpu

# GPU memory pre-allocation fraction (FLAGS_fraction_of_gpu_memory_to_use).
# 0.0 = on-demand (recommended for ≤8 GB cards — avoids OOM on inference casts).
# 0.85 = pre-allocate 85% upfront (lower latency, only for ≥12 GB VRAM).
PADDLE_VL_GPU_MEM_FRACTION=0.0
EXTRACTION_MAX_FILE_SIZE_MB=20

# ─── Gemini / Google AI API ───────────────────────────────────────────────────
# Option A – API key (Google AI API, no service account needed):
GOOGLE_API_KEY=your-google-ai-api-key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
VERTEX_MODEL=gemini-2.0-flash

# Option B – Vertex AI (service account / Workload Identity, leave GOOGLE_API_KEY blank):
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# Option C – Vertex AI multi-project rotation to avoid 429 rate limits.
# Uses the same ADC credentials — each project has its own independent quota.
# On each 429 the extractor immediately switches to the next project (no wait).
# Back-off only applies after ALL listed projects are exhausted in one round.
# Overrides GOOGLE_CLOUD_PROJECT when set. Use JSON array format:
# GOOGLE_CLOUD_PROJECTS=["your-project-1","your-project-2","your-project-3"]

# Option D – Google AI API multi-key rotation (if you use API keys instead of ADC).
# Each key is a separate AI Studio project with its own quota.
# Rotation behaviour is identical to Option C.
# Overrides GOOGLE_API_KEY when set. Use JSON array format:
# GOOGLE_AI_API_KEYS=["AIza...key1","AIza...key2","AIza...key3"]

# ─── Azure Document Intelligence (alternative provider) ───────────────────────
AZURE_DOCINTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCINTEL_KEY=your-azure-key
AZURE_DOCINTEL_MODEL_ID=prebuilt-document

# ─── Odoo ─────────────────────────────────────────────────────────────────────
ODOO_URL=https://your-odoo.example.com
ODOO_DB=your_database
ODOO_USERNAME=api_user@example.com
ODOO_PASSWORD=your-odoo-api-key
ODOO_TIMEOUT=30
ODOO_RETRIES=3
